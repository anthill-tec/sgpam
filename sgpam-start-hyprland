#!/bin/sh
# sgpam-start-hyprland — blank screen via DRM, then launch Hyprland
# Usage: sgpam-start-hyprland [--verbose|-v] [hyprland args...]

VERBOSE=0
ARGS=""
for arg in "$@"; do
    case "$arg" in
        -v|--verbose) VERBOSE=1 ;;
        *) ARGS="$ARGS $arg" ;;
    esac
done

if [ "$VERBOSE" -eq 1 ]; then
    echo "sgpam: blanking DRM displays (verbose)..." >&2
    sg-drm-blank --verbose
    echo "sgpam: launching start-hyprland$ARGS" >&2
else
    sg-drm-blank
fi
exec start-hyprland $ARGS
